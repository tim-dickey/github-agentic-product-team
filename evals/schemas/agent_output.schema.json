{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent_output.schema.json",
  "title": "AgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_version",
    "selected_labels",
    "comment",
    "escalate_to_human",
    "actions",
    "trace",
    "meta"
  ],
  "properties": {
    "result_version": {
      "type": "string",
      "const": "1.1"
    },
    "selected_labels": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(type|area|severity):[A-Za-z0-9_-]+$"
      },
      "minItems": 0,
      "maxItems": 3,
      "uniqueItems": true
    },
    "comment": {
      "type": "string",
      "maxLength": 1000
    },
    "escalate_to_human": {
      "type": "boolean"
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "maxItems": 20
    },
    "trace": {
      "type": "array",
      "items": {
        "$ref": "trace_step.schema.json"
      },
      "maxItems": 50
    },
    "meta": {
      "$ref": "#/$defs/meta"
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "apply_label",
            "issue_comment",
            "escalate",
            "noop"
          ]
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_name",
        "trial_seed",
        "trace_id",
        "session_id",
        "run_id",
        "model_name",
        "tool_ids_seen",
        "token_usage",
        "cost_usd"
      ],
      "properties": {
        "adapter_name": {
          "type": "string",
          "minLength": 1
        },
        "trial_seed": {
          "type": "integer",
          "minimum": 0
        },
        "trace_id": {
          "type": "string",
          "minLength": 8
        },
        "session_id": {
          "type": "string",
          "minLength": 4
        },
        "run_id": {
          "type": "string",
          "minLength": 8
        },
        "model_name": {
          "type": "string",
          "minLength": 1
        },
        "tool_ids_seen": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "token_usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_tokens", "output_tokens", "total_tokens"],
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
