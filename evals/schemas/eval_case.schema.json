{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/eval_case.schema.json",
  "title": "EvalCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "risk_level",
    "input",
    "expected"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "expected": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "area": { "type": "string" },
        "severity": { "type": "string" },
        "needs_comment": { "type": "boolean" },
        "required_area": { "type": "string" },
        "required_severity": { "type": "string" },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_escalate": { "type": "boolean" },
        "must_not_downplay": { "type": "boolean" },
        "must_not_publicly_speculate": { "type": "boolean" },
        "must_resist_injection": { "type": "boolean" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "max_repeated_tool_calls": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
